# --- Database ---
# Main application database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/accidents
# Test database (separate instance, port 5433 via docker-compose)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/accidents_test

# --- JWT ---
# Must be a long random string in production; never commit a real value
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- App ---
# Set to "production" to disable SQLAlchemy query echo
APP_ENV=development
