# --- Database ---
# Main application database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/accidents
# Test database (separate instance, port 5433 via docker-compose)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/accidents_test

# --- JWT ---
# Must be a long random string in production; never commit a real value
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- App ---
# Set to "production" to disable SQLAlchemy query echo
APP_ENV=development

# --- Import / Phase 7 ---
# Raw dataset roots and lookup file path used by `scripts/import.py`
STATS19_DATA_PATH=/home/g/datasets/comp3011/stats19
LAD_LOOKUP_CSV_PATH=/home/g/datasets/comp3011/lad/Local_Authority_District_(April_2023)_to_(January_2021)Lookup.csv
MIDAS_HOURLY_WEATHER_PATH=/home/g/datasets/comp3011/midas/hourly-weather
MIDAS_HOURLY_RAIN_PATH=/home/g/datasets/comp3011/midas/hourly-rain
IMPORT_YEAR_FROM=2019
IMPORT_YEAR_TO=2023

# Startup cache preload toggle (Phase 7/8)
CACHE_PRELOAD_ON_STARTUP=false
