# Copy to .env.prod and update values before deployment.

# Postgres container credentials used by docker-compose.prod.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=accidents

# App security
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Runtime mode
APP_ENV=production

# Route-risk startup cache preload
CACHE_PRELOAD_ON_STARTUP=true

# CORS (leave blank for same-origin deployments)
CORS_ALLOW_ORIGINS=
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Container process behavior
RUN_MIGRATIONS=true
UVICORN_WORKERS=2
UVICORN_LOG_LEVEL=info
